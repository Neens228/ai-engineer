{
  // Учебный режим: отключаем автодополнение Copilot (серый "призрачный" текст),
  // чтобы тренироваться писать код самому. Чат с Copilot при этом продолжает работать.
  "github.copilot.enable": {
    "*": false
  },
  // На всякий случай отключаем и встроенные inline-подсказки редактора.
  "editor.inlineSuggest.enabled": false
}
